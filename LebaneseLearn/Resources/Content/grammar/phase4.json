  {
    "id": "p4-grammar-relative-clauses",
    "phaseId": 4,
    "title": "Relative Clauses with يلي (yalli)",
    "tag": "Key Structure",
    "explanation": "يلي (yalli) means 'who / which / that' and is the Lebanese replacement for MSA الذي / التي / الذين. It never changes for gender or number — one form covers everything. It connects a noun to a clause that describes it.",
    "examples": [
      {
        "arabic": "الزلمة يلي بيشتغل هون",
        "transliteration": "iz-zalame yalli byishteghil hōn",
        "english": "The man who works here",
        "breakdown": "الزلمة (the man) + يلي (who) + بيشتغل (works) + هون (here)"
      },
      {
        "arabic": "الأكل يلي عملتو كتير طيب",
        "transliteration": "il-akl yalli ʕmalto ktīr ṭayyeb",
        "english": "The food that you made is really good",
        "breakdown": "الأكل (the food) + يلي (that) + عملتو (you made it)"
      },
      {
        "arabic": "البنت يلي حكيت معا",
        "transliteration": "il-bint yalli ḥkīt maʕa",
        "english": "The girl that I spoke with",
        "breakdown": "البنت (the girl) + يلي (that) + حكيت (I spoke) + معا (with her)"
      },
      {
        "arabic": "هيدا يلي قصدتو",
        "transliteration": "hayda yalli ʔaṣadto",
        "english": "This is what I meant",
        "breakdown": "هيدا (this) + يلي (what/that) + قصدتو (I meant it)"
      }
    ]
  },
